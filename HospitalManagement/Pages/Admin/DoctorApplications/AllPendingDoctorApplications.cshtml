@page
@model HospitalManagement.Pages.Admin.DoctorApplications.AllPendingDoctorApplicationsModel
@{

    Layout = "/Pages/Admin/_AdminLayout.cshtml";
    int count = 1;
}
<div class="card">
    <div class="card-header">
        <h2>
            All Pending DoctorApplications
        </h2>

    </div>

    <div class="card-body">

        <div class="table-responsive">
            <table class="table table-hover table-centered">
                <thead class="table-light">
                    <tr>
                        <th scope="col">No</th>
                        <th scope="col">FirstName</th>
                        <th scope="col">LastName</th>
                        <th scope="col">Gender</th>
                        <th scope="col">DateOfBirth</th>
                        <th scope="col">MobileNo</th>
                        <th scope="col">Email</th>
                        <th scope="col">Department Name</th>
                        <th scope="col">ProfilePhotoPath</th>
                        <th scope="col">ResumePath</th>
                        <th scope="col">RequestDate</th>
                        <th scope="col">ApplicationStatus</th>
                        <th scope="col">View</th>

                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.AllPendingDoctorApplications)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-1">

                                    <div class="d-block">
                                        <h5 class="mb-0">@count</h5>
                                    </div>
                                </div>
                            </td>
                            <td>@item.FirstName</td>
                            <td>@item.LastName</td>
                            <td>@item.Gender</td>
                            <td>@item.DateOfBirth</td>
                            <td>@item.MobileNo</td>
                            <td>@item.Email</td>
                            <td>@item.DepartmentName</td>

                            <td>
                                <img src="~/@item.ProfilePhotoPath"
                                     width="80"
                                     height="80"
                                     style="object-fit:cover; border-radius:5px;" />
                            </td>
                            <td>
                                <img src="~/@item.ResumePath"
                                     width="80"
                                     height="80"
                                     style="object-fit:cover; border-radius:5px;" />
                            </td>
                            <td>@item.RequestDate</td>

                            <td>@item.ApplicationStatus</td>


                        
                            <td><a asp-page="/Admin/DoctorApplications/SingleDoctorApplications" asp-route-id="@item.DoctorApplicationsId" class="btn btn-success btn-sm w-100">View</a></td>
                          

                            <td>
                              </td>

                          
                        </tr>
                        count++;
                    }


                </tbody>
            </table>
        </div>
    </div>
</div>